@host = http://localhost:5176

### List all players
GET {{host}}/players
Accept: application/json

# @name createdPlayer
POST {{host}}/players
Content-Type: application/json

{ "name": "Gui" }

###
GET {{host}}/players/{{createdPlayer.response.body.id}}

### Update a player
PUT {{host}}/players/1
Content-Type: application/json

{
  "name": "Guilherme"
}

### Delete a player
DELETE {{host}}/players/1

### List all decks
GET {{host}}/decks
Accept: application/json

### Get deck by id
GET {{host}}/decks/1
Accept: application/json

### Create a deck (requires PlayerId of an existing player — create one via /players first if needed)
POST {{host}}/decks
Content-Type: application/json

{
  "name": "Atraxa Superfriends",
  "commanderName": "Atraxa, Praetors' Voice",
  "playerId": 6
}

### Update a deck (replace 1 with the id returned from the POST above)
PUT {{host}}/decks/1
Content-Type: application/json

{
  "name": "Atraxa Superfriends (v2)",
  "commanderName": "Atraxa, Praetors' Voice",
  "playerId": 1
}

### Delete a deck
DELETE {{host}}/decks/1

### Confirm deletion (should 404)
GET {{host}}/decks/1

### Create game
# @name createdGame
POST {{host}}/games
Content-Type: application/json

{
  "Participants": [
    {
      "PlayerId": 3,
      "DeckId": 2
    },
    {
      "PlayerId": 6,
      "DeckId": 3
    }
  ]
}

### Update game
PUT {{host}}/games/{{createdGame.response.body.id}}/result
Content-Type: application/json

{
  "WinnerGamePlayerId": 27
}

### Get games
GET {{host}}/games

### Delete a game
DELETE {{host}}/games/13